# ===== APP =====
APP_ENV=development
LOG_LEVEL=INFO

# ===== POSTGRES =====
POSTGRES_DB=ecs_db
POSTGRES_USER=ecs_user
POSTGRES_PASSWORD=ecs_password
POSTGRES_PORT=5433

DATABASE_URL=postgresql+psycopg://ecs_user:ecs_password@postgres:5432/ecs_db

# ===== KAFKA =====
# ВАЖНО: для контейнеров
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Для доступа с хоста (если нужно руками тестить)
KAFKA_BOOTSTRAP_SERVERS_EXTERNAL=localhost:19092

# ===== SERVICES =====
INGESTION_PORT=8000
