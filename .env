# ----------------------------
# Application
# ----------------------------
APP_ENV=development
INGESTION_PORT=8000
OPTIMIZER_PORT=8001
INTRADAY_PORT=8002

# ----------------------------
# PostgreSQL
# ----------------------------
POSTGRES_DB=ecs_db
POSTGRES_USER=ecs_user
POSTGRES_PASSWORD=ecs_password
POSTGRES_PORT=5433

# Used by the ingestion service
DATABASE_URL=postgresql+psycopg://ecs_user:ecs_password@postgres:5432/ecs_db

# ----------------------------
# Kafka
# ----------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ----------------------------
# Optional app settings
# ----------------------------
LOG_LEVEL=INFO
